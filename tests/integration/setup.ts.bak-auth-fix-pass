import { config } from "dotenv";
config({ path: ".env.test" });

import { afterAll, beforeAll, beforeEach, vi } from "vitest";
import { db } from "@/lib/db";

async function resetFinancialTestState() {
  await db.$transaction([
    db.notification.deleteMany(),
    db.auditLog.deleteMany(),
    db.payoutRequest.deleteMany(),
    db.depositRequest.deleteMany(),
    db.ledgerHold.deleteMany(),
    db.journalLine.deleteMany(),
    db.journalEntry.deleteMany(),
    db.wallet.deleteMany(),
    db.ledgerAccount.deleteMany(),
    db.user.deleteMany(),
  ]);
}

beforeAll(async () => {
  await db.$connect();
});

beforeEach(async () => {
  vi.restoreAllMocks();
  await resetFinancialTestState();
});

afterAll(async () => {
  await resetFinancialTestState();
  await db.$disconnect();
});