model LedgerAccount {
  id                String                @id @default(cuid())
  ownerId           String?
  slug              String                @unique
  currency          String                @default("SYP")
  balance           Float                 @default(0)
  metadata          Json?
  status            String                @default("ACTIVE")
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  creditLimit       Float                 @default(0)
