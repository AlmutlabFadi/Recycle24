  debtDueAt         DateTime?
  debtLockReason    String?
  debtStatus        String                @default("CLEAR")
  lockedByDebt      Boolean               @default(false)
  waiverPolicies    AccountWaiverPolicy[]
  depositRequests   DepositRequest[]
