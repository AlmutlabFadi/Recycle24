  senderAccount     LedgerAccount? @relation("SenderAccountTransfers", fields: [senderAccountId], references: [id], onDelete: Cascade)
  sender            User           @relation("SenderTransfers", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([senderId])
  @@index([receiverId])
  @@index([status])
  @@index([createdAt])
