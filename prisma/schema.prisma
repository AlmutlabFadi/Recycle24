generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                         String                      @id @default(cuid())
  phone                      String?                     @unique
  email                      String?                     @unique
  password                   String
  name                       String?
  firstName                  String?
  lastName                   String?
  titleId                    String?
  gender                     String                      @default("unknown")
  userType                   String                      @default("CLIENT")
  status                     String                      @default("PENDING")
  role                       String                      @default("CLIENT")
  isVerified                 Boolean                     @default(false)
  createdAt                  DateTime                    @default(now())
  updatedAt                  DateTime                    @updatedAt
  isLocked                   Boolean                     @default(false)
  lockReason                 String?
  companyName                String?
  companyType                String?
  companyTypeOther           String?
  businessType               String?
  businessTypeOther          String?
  jobTitle                   String?
  jobTitleOther              String?
  bio                        String?
  notifEmail                 Boolean                     @default(true)
  notifSms                   Boolean                     @default(false)
  notifWhatsapp              Boolean                     @default(false)
  notifTelegram              Boolean                     @default(false)
  notifPush                  Boolean                     @default(true)
  notifDeals                 Boolean                     @default(true)
  notifAuctions              Boolean                     @default(true)
  notifMarketing             Boolean                     @default(false)
  smsPhone                   String?
  whatsappPhone              String?
  telegramUsername           String?
  verificationCode           String?
  verificationExpiry         DateTime?
  twoFactorEnabled           Boolean                     @default(false)
  twoFactorMethod            String?
  faceIdEnabled              Boolean                     @default(false)
  showPhone                  Boolean                     @default(false)
  hideWarehouseLocation      Boolean                     @default(false)
  allowFactoryContact        Boolean                     @default(true)
  breakTimes                 String?
  currentAdminStatus         String                      @default("OFFLINE")
  adminAccessEnabled         Boolean                     @default(true)
  dailyWorkHours             Float?
  lastActiveAt               DateTime?
  vacationDays               Int                         @default(0)
  achievements               Achievement[]
  auctions                   Auction[]
  auctionParticipations      AuctionParticipant[]
  auctionPenalties           AuctionPenalty[]
  bids                       Bid[]
  deals                      Deal[]                      @relation("buyer")
  soldDeals                  Deal[]                      @relation("seller")
  depositRequests            DepositRequest[]
  deviceSessions             DeviceSession[]
  driver                     Driver?
  knowledgeItems             KnowledgeItem[]
  notifications              Notification[]
  payoutRequests             PayoutRequest[]
  alerts                     PriceAlert[]
  recyclePoints              RecyclePoints?
  reviewsReceived            Review[]                    @relation("reviewee")
  reviewsGiven               Review[]                    @relation("reviewer")
  safetyChecklistSubmissions SafetyChecklistSubmission[]
  safetyIncidentReports      SafetyIncidentReport[]
  safetyIncidentStatusLogs   SafetyIncidentStatusLog[]
  safetyTrainingRequests     SafetyTrainingRequest[]
  securityLogs               SecurityLog[]
  securityOTPs               SecurityOTP[]
  sessions                   Session[]
  staffActivities            StaffActivity[]
  invitesCreated             StaffInvite[]
  invitesUsed                StaffInvite[]               @relation("InviteUsedBy")
  issuedWarnings             StaffWarning[]              @relation("WarningIssuer")
  staffWarnings              StaffWarning[]
  StolenReport               StolenReport[]
  supportTickets             SupportTicket[]
  trader                     Trader?
  receivedTransfers          TransferRequest[]           @relation("ReceiverTransfers")
  sentTransfers              TransferRequest[]           @relation("SenderTransfers")
  userRoles                  UserRole[]
  subscription               UserSubscription?
  wallet                     Wallet?
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   @default("INFO")
  isRead    Boolean  @default(false)
  link      String?
  metadata  Json?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model Session {
  id         String   @id @default(cuid())
  userId     String
  token      String   @unique
  device     String?
  deviceType String?  @default("phone")
  location   String?
  ip         String?
  userAgent  String?
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Trader {
  id                        String           @id @default(cuid())
  userId                    String           @unique
  businessName              String
  licenseNumber             String?
  location                  String?
  verificationStatus        String           @default("PENDING")
  verifiedAt                DateTime?
  createdAt                 DateTime         @default(now())
  updatedAt                 DateTime         @updatedAt
  missingDocuments          String[]         @default([])
  rejectionReason           String?
  chamberMembershipYear     Int?
  chamberRegistrationNumber String?
  chamberSerialNumber       String?
  expiryDate                DateTime?
  governorate               String?
  issueDate                 DateTime?
  registrationNumber        String?
  taxNumber                 String?
  dateOfBirth               DateTime?
  fatherName                String?
  motherName                String?
  fieldStatuses             Json?            @default("{}")
  successRate               Float            @default(100.0)
  totalReviews              Int              @default(0)
  trustScore                Float            @default(0.0)
  user                      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents                 TraderDocument[]

  @@index([verificationStatus])
}

model TraderDocument {
  id        String   @id @default(cuid())
  traderId  String
  type      String
  fileUrl   String
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  trader    Trader   @relation(fields: [traderId], references: [id], onDelete: Cascade)

  @@index([traderId])
  @@index([status])
  @@index([traderId, createdAt])
}

model Auction {
  id                      String                     @id @default(cuid())
  sellerId                String
  title                   String
  category                String
  weight                  Float
  weightUnit              String                     @default("KG")
  location                String
  startingBid             Float
  buyNowPrice             Float?
  securityDeposit         Float                      @default(0)
  entryFee                Float                      @default(0)
  duration                Int
  status                  String                     @default("SCHEDULED")
  scheduledAt             DateTime?
  startedAt               DateTime?
  endsAt                  DateTime?
  winnerId                String?
  finalPrice              Float?
  currentBid              Float?
  createdAt               DateTime                   @default(now())
  updatedAt               DateTime                   @updatedAt
  depositPercent          Float                      @default(0)
  effectiveEndsAt         DateTime?
  extensionCount          Int                        @default(0)
  extensionStage          AuctionExtensionStage      @default(NONE)
  finalClosedAt           DateTime?
  govWaiverFileUrl        String?
  govWaiverRequired       Boolean                    @default(false)
  isFinallyClosed         Boolean                    @default(false)
  lastExtensionAt         DateTime?
  originalEndsAt          DateTime?
  requiresESign           Boolean                    @default(true)
  reservePrice            Float?
  type                    AuctionType                @default(PRIVATE)
  winningBidId            String?
  workflowStatus          AuctionWorkflowStatus      @default(DRAFT)
  allowPreview            Boolean                    @default(false)
  buyNowPriceCurrency     String                     @default("SYP")
  notes                   String?
  organization            String?
  previewEndDate          DateTime?
  previewEndTime          String?
  previewStartDate        DateTime?
  previewStartTime        String?
  pricingMode             String                     @default("unified")
  securityDepositCurrency String                     @default("SYP")
  securityDepositMethod   String                     @default("platform")
  shipmentDurationDays    Int?
  startingBidCurrency     String                     @default("SYP")
  startingBidUnit         String                     @default("total")
  version                 Int                        @default(0)
  auctionDirection        AuctionDirection           @default(FORWARD)
  auctionDomain           AuctionDomain              @default(ASSET_SALE)
  currency                String                     @default("SYP")
  disputeWindowHours      Int?
  governingLaw            String?
  jurisdictionCountry     String?
  pricingModeV2           AuctionPricingMode         @default(LOT_BASED)
  winnerSelectionMode     AuctionWinnerSelectionMode @default(PER_LOT)
  jurisdictionCity        String?
  seller                  User                       @relation(fields: [sellerId], references: [id])
  disputes                AuctionDispute[]
  documents               AuctionDocument[]
  events                  AuctionEventLog[]
  images                  AuctionImage[]
  items                   AuctionItem[]
  lots                    AuctionLot[]
  participants            AuctionParticipant[]
  participantLots         AuctionParticipantLot[]
  penalties               AuctionPenalty[]
  bids                    Bid[]

  @@index([sellerId])
  @@index([category])
  @@index([status])
  @@index([type, workflowStatus])
  @@index([endsAt])
  @@index([effectiveEndsAt])
  @@index([winnerId])
  @@index([winningBidId])
}

model AuctionLot {
  id                    String                  @id @default(cuid())
  auctionId             String
  title                 String
  description           String?
  quantity              Float
  unit                  String
  currency              String                  @default("SYP")
  direction             AuctionDirection        @default(FORWARD)
  startingPrice         Float
  reservePrice          Float?
  buyNowPrice           Float?
  depositModeOverride   AuctionDepositMode      @default(NONE)
  depositAmountOverride Float                   @default(0)
  status                AuctionLotStatus        @default(DRAFT)
  winnerId              String?
  winningBidId          String?
  finalPrice            Float?
  version               Int                     @default(0)
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  category              String
  currentBestBid        Float?
  lineNo                Int
  pricingUnit           String
  auction               Auction                 @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  participantLots       AuctionParticipantLot[]
  bids                  Bid[]

  @@index([auctionId])
  @@index([status])
  @@index([winnerId])
  @@index([winningBidId])
}

model AuctionItem {
  id         String   @id @default(cuid())
  auctionId  String
  type       String
  customType String?
  weight     Float
  unit       String   @default("kg")
  isAccurate Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  auction    Auction  @relation(fields: [auctionId], references: [id], onDelete: Cascade)

  @@index([auctionId])
}

model AuctionDocument {
  id        String   @id @default(cuid())
  auctionId String
  fileUrl   String
  fileName  String?
  fileType  String?
  fileSize  Int?
  createdAt DateTime @default(now())
  auction   Auction  @relation(fields: [auctionId], references: [id], onDelete: Cascade)

  @@index([auctionId])
}

model AuctionParticipant {
  id                    String                           @id @default(cuid())
  auctionId             String
  userId                String
  depositPaid           Float                            @default(0)
  entryFeePaid          Float                            @default(0)
  isExempt              Boolean                          @default(false)
  depositStatus         String                           @default("HELD")
  createdAt             DateTime                         @default(now())
  updatedAt             DateTime                         @updatedAt
  agreedToCommission    Boolean                          @default(false)
  agreedToDataSharing   Boolean                          @default(false)
  agreedToPrivacy       Boolean                          @default(false)
  agreedToTerms         Boolean                          @default(false)
  agreedToInvoice       Boolean                          @default(false)
  hasInspectedGoods     Boolean                          @default(false)
  approvedAt            DateTime?
  depositHoldId         String?
  depositWorkflowStatus AuctionDepositWorkflowStatus     @default(NONE)
  rejectedAt            DateTime?
  rejectionReason       String?
  workflowStatus        AuctionParticipantWorkflowStatus @default(PENDING)
  auction               Auction                          @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  user                  User                             @relation(fields: [userId], references: [id])
  selectedLots          AuctionParticipantLot[]

  @@unique([auctionId, userId])
  @@index([auctionId])
  @@index([userId])
  @@index([workflowStatus])
  @@index([depositWorkflowStatus])
  @@index([depositHoldId])
}

model AuctionParticipantLot {
  id                    String                              @id @default(cuid())
  auctionId             String
  participantId         String
  lotId                 String
  isSelected            Boolean                             @default(true)
  depositHoldId         String?
  depositWorkflowStatus AuctionDepositWorkflowStatus        @default(NONE)
  workflowStatus        AuctionParticipantLotWorkflowStatus @default(SELECTED)
  createdAt             DateTime                            @default(now())
  updatedAt             DateTime                            @updatedAt
  depositRequired       Float                               @default(0)
  auction               Auction                             @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  lot                   AuctionLot                          @relation(fields: [lotId], references: [id], onDelete: Cascade)
  participant           AuctionParticipant                  @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@unique([participantId, lotId])
  @@index([participantId])
  @@index([lotId])
  @@index([depositHoldId])
  @@index([depositWorkflowStatus])
  @@index([workflowStatus])
}

model AuctionImage {
  id        String   @id @default(cuid())
  auctionId String
  imageUrl  String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  auction   Auction  @relation(fields: [auctionId], references: [id], onDelete: Cascade)

  @@index([auctionId])
}

model Bid {
  id              String            @id @default(cuid())
  auctionId       String
  bidderId        String
  amount          Float
  createdAt       DateTime          @default(now())
  acceptedAt      DateTime?
  participantId   String?
  rejectedAt      DateTime?
  rejectionReason String?
  status          BidWorkflowStatus @default(ACTIVE)
  requestKey      String?           @unique
  lotId           String?
  auction         Auction           @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  bidder          User              @relation(fields: [bidderId], references: [id])
  lot             AuctionLot?       @relation(fields: [lotId], references: [id], onDelete: Cascade)

  @@index([auctionId, createdAt])
  @@index([auctionId, amount])
  @@index([lotId])
  @@index([bidderId, createdAt])
  @@index([status])
}

model AuctionEventLog {
  id        String   @id @default(cuid())
  auctionId String
  actorId   String?
  eventType String
  payload   Json?
  createdAt DateTime @default(now())
  auction   Auction  @relation(fields: [auctionId], references: [id], onDelete: Cascade)

  @@index([auctionId, createdAt])
  @@index([eventType, createdAt])
}

model AuctionDispute {
  id          String               @id @default(cuid())
  auctionId   String
  openedById  String
  status      AuctionDisputeStatus @default(OPEN)
  subject     String
  description String
  resolution  String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  auction     Auction              @relation(fields: [auctionId], references: [id], onDelete: Cascade)

  @@index([auctionId, status])
}

model AuctionPenalty {
  id         String             @id @default(cuid())
  auctionId  String
  userId     String
  type       AuctionPenaltyType
  amount     Float?
  reason     String
  createdAt  DateTime           @default(now())
  resolvedAt DateTime?
  auction    Auction            @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  user       User               @relation(fields: [userId], references: [id])

  @@index([auctionId, userId])
  @@index([userId, type])
}

model Deal {
  id             String        @id @default(cuid())
  auctionId      String?
  sellerId       String
  buyerId        String
  materialType   String
  weight         Float
  totalAmount    Float
  platformFee    Float
  status         String        @default("PENDING")
  contractSigned Boolean       @default(false)
  signedAt       DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  currency       String        @default("SYP")
  buyer          User          @relation("buyer", fields: [buyerId], references: [id])
  seller         User          @relation("seller", fields: [sellerId], references: [id])
  reviews        Review[]
  transactions   Transaction[]

  @@index([sellerId])
  @@index([buyerId])
  @@index([status])
}

model Wallet {
  id           String        @id @default(cuid())
  userId       String        @unique
  balanceSYP   Float         @default(0)
  balanceUSD   Float         @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  transactions Transaction[]
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Transaction {
  id          String   @id @default(cuid())
  walletId    String
  dealId      String?
  type        String
  amount      Float
  currency    String
  status      String
  description String?
  createdAt   DateTime @default(now())
  deal        Deal?    @relation(fields: [dealId], references: [id])
  wallet      Wallet   @relation(fields: [walletId], references: [id])

  @@index([walletId])
  @@index([dealId])
  @@index([status])
  @@index([createdAt])
}

model PriceAlert {
  id          String   @id @default(cuid())
  userId      String
  metal       String
  targetPrice Float
  condition   String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isActive])
}

model RecyclePoints {
  id        String   @id @default(cuid())
  userId    String   @unique
  points    Int      @default(0)
  level     Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Achievement {
  id         String   @id @default(cuid())
  userId     String
  badgeType  String
  unlockedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model SubscriptionPackage {
  id            String             @id @default(cuid())
  name          String             @unique
  price         Float
  durationDays  Int                @default(30)
  benefits      String[]
  isActive      Boolean            @default(true)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  subscriptions UserSubscription[]
}

model UserSubscription {
  id        String               @id @default(cuid())
  userId    String               @unique
  packageId String?
  plan      String               @default("FREE")
  status    String               @default("ACTIVE")
  startDate DateTime             @default(now())
  endDate   DateTime?
  pricePaid Float                @default(0)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  package   SubscriptionPackage? @relation(fields: [packageId], references: [id])
  user      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CompanyWallet {
  id               String   @id @default(cuid())
  totalRevenue     Float    @default(0)
  totalCommissions Float    @default(0)
  totalDeposits    Float    @default(0)
  balanceSYP       Float    @default(0)
  balanceUSD       Float    @default(0)
  updatedAt        DateTime @updatedAt
}

model SecurityLog {
  id        String   @id @default(cuid())
  level     String
  event     String
  details   String?
  ip        String?
  userAgent String?
  userId    String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@index([event])
  @@index([level])
  @@index([createdAt])
}

model Agent {
  id            String      @id @default(cuid())
  name          String      @unique
  type          String
  status        String      @default("IDLE")
  lastHeartbeat DateTime    @default(now())
  metadata      String?
  ipAddress     String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  tasks         AgentTask[] @relation("assignedAgent")

  @@index([type])
  @@index([status])
  @@index([lastHeartbeat])
}

model AgentTask {
  id            String    @id @default(cuid())
  type          String
  priority      Int       @default(0)
  status        String    @default("PENDING")
  payload       String?
  result        String?
  error         String?
  assignedToId  String?
  retryCount    Int       @default(0)
  maxRetries    Int       @default(3)
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  assignedAgent Agent?    @relation("assignedAgent", fields: [assignedToId], references: [id])

  @@index([status])
  @@index([priority])
  @@index([type])
  @@index([assignedToId])
}

model TransportBooking {
  id                  String   @id @default(cuid())
  userId              String
  trackingId          String   @unique
  materialType        String
  weight              Float
  pickupAddress       String
  pickupGovernorate   String
  deliveryAddress     String
  deliveryGovernorate String
  pickupDate          DateTime
  notes               String?
  transportType       String
  status              String   @default("PENDING")
  estimatedPrice      Float
  actualPrice         Float?
  driverId            String?
  driverName          String?
  driverPhone         String?
  vehicleType         String?
  plateNumber         String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([userId])
  @@index([trackingId])
  @@index([status])
  @@index([driverId])
}

model SupportTicket {
  id        String                 @id @default(cuid())
  userId    String
  ticketId  String                 @unique
  subject   String
  category  String                 @default("عام")
  priority  String                 @default("MEDIUM")
  status    String                 @default("OPEN")
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt
  user      User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  SupportTicketMessage[]

  @@index([userId])
  @@index([ticketId])
  @@index([status])
  @@index([priority])
}

model SupportTicketMessage {
  id         String        @id @default(cuid())
  ticketId   String
  userId     String?
  content    String
  senderType String
  createdAt  DateTime      @default(now())
  ticket     SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([createdAt])
}

model AgentReport {
  id         String   @id @default(cuid())
  agentName  String
  taskType   String
  severity   String   @default("INFO")
  category   String
  file       String?
  line       Int?
  message    String
  suggestion String?
  codeBefore String?
  codeAfter  String?
  autoFixed  Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([severity])
  @@index([agentName])
  @@index([taskType])
  @@index([autoFixed])
  @@index([createdAt])
}

model GsoccIncident {
  id           String   @id @default(cuid())
  title        String
  description  String?
  severity     String   @default("MEDIUM")
  status       String   @default("OPEN")
  sourceIp     String?  @map("source_ip")
  userId       String?  @map("user_id")
  incidentType String   @map("incident_type")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("gsocc_incidents")
}

model GsoccEvidenceLog {
  id               String   @id @default(cuid())
  incidentId       String   @map("incident_id")
  actionTaken      String   @map("action_taken")
  executedBy       String   @map("executed_by")
  evidenceSnapshot Json?    @map("evidence_snapshot")
  hashSignature    String?  @map("hash_signature")
  createdAt        DateTime @default(now()) @map("created_at")

  @@map("gsocc_evidence_logs")
}

model GsoccSecurityRule {
  id          String   @id @default(cuid())
  ruleType    String   @map("rule_type")
  targetValue String   @map("target_value")
  action      String
  createdBy   String   @map("created_by")
  reason      String?
  incidentId  String?  @map("incident_id")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("gsocc_security_rules")
}

model StolenReport {
  id             String   @id @default(cuid())
  userId         String?
  reportingOrg   String
  type           String
  customItemType String?
  description    String
  location       String
  contactPhone   String
  plateNumber    String?
  vehicleType    String?
  vehicleColor   String?
  stolenDate     DateTime
  status         String   @default("ACTIVE")
  images         String[] @default([])
  videos         String[] @default([])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([type])
  @@index([createdAt])
}

model KnowledgeItem {
  id            String   @id @default(cuid())
  center        String
  type          String
  title         String
  summary       String?
  content       String?
  mediaUrl      String?
  coverImageUrl String?
  tags          String[] @default([])
  priority      Int      @default(0)
  status        String   @default("DRAFT")
  authorName    String?
  sourceLabel   String?
  createdById   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  createdBy     User?    @relation(fields: [createdById], references: [id])

  @@index([center])
  @@index([type])
  @@index([status])
  @@index([priority])
