  holds             LedgerHold[]
  payoutRequests    PayoutRequest[]
  incomingTransfers TransferRequest[]     @relation("ReceiverAccountTransfers")
  outgoingTransfers TransferRequest[]     @relation("SenderAccountTransfers")

  @@index([ownerId])
  @@index([slug])
  @@index([status])
  @@index([debtStatus])
  @@index([lockedByDebt])
}

model JournalEntry {
