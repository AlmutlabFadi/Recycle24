  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  account       LedgerAccount @relation(fields: [accountId], references: [id])

  @@index([accountId])
  @@index([status])
  @@index([referenceId])
  @@index([accountId, status])
}

model DepositRequest {
